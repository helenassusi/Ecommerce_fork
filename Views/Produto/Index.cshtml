@using Azure.Core 
@model IEnumerable<Esse_deu_certo_MVC_Exemplo.Models.Produto>

@{
    ViewData["Title"] = "Catálogo de Produtos";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">
    <h2 class="mb-4 text-center">🛍️ Catálogo de Produtos</h2>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="busca" class="form-control" placeholder="Buscar produtos..." value="@Context.Request.Query["busca"]" />
        </div>
        <div class="col-md-3">
            <select name="categoria" class="form-select">
                <option value="">Todas as categorias</option>
                @foreach (var c in ViewBag.Categorias) // foreach para popular categorias
                {
                    <option value="@c.Value" selected="@(@Context.Request.Query["categoria"] == c.Value)">
                        @c.Text
                    </option>
                }

            </select>
        </div>
        <div class="col-md-3">
            <select name="ordenacao" class="form-select">
                <option value="">Ordenar por...</option>
                <option value="preco_asc">Menor preço</option>
                <option value="preco_desc">Maior preço</option>
                <option value="novo">Mais recentes</option>
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>

    <div class="row">
        @if (Model.Any())
        {
            @foreach (var p in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@p.ImagemUrl" class="card-img-top" alt="@p.Nome" style="height: 200px; object-fit: cover;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@p.Nome</h5>
                            <p class="text-muted">@p.Categoria?.Nome</p>
                            <p class="fw-bold text-success">R$ @p.Preco.ToString("F2")</p>
                            <p class="text-truncate">@p.Descricao</p>
                            <a asp-controller="Carrinho"
                               asp-action="Adicionar"
                               asp-route-produtoId="@p.Id"
                               class="btn btn-warning mt-auto">
                                🛒 Adicionar ao carrinho
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-center">Nenhum produto encontrado.</p>
        }
    </div>
</div>
