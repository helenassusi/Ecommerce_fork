@model Esse_deu_certo_MVC_Exemplo.Models.Dashboard
@using Newtonsoft.Json

@{
    ViewData["Title"] = "Painel do Administrador";
    var categorias = ViewBag.Categorias as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="mb-3">
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">🏠 Dashboard</a>
    <a asp-controller="Admin" asp-action="CadastrarProduto" class="btn btn-primary">➕ Cadastrar Produto</a>
    <a href="/Admin/Produtos" class="btn btn-info">📦 Gerenciar Produtos</a>
    <a href="/Admin/Usuarios" class="btn btn-danger">👨‍💼 Gerenciar Usuários</a>
    <a asp-controller="Categoria" asp-action="Index" class="btn btn-warning">📁 Categorias</a> <!-- ✅ Novo link -->
    <a asp-controller="Usuario" asp-action="Logout" class="btn btn-danger float-end">🚪 Sair</a>
</div>


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4">
    <h2 class="text-center mb-4">📊 Dashboard Administrativo</h2>

    <!-- Cards de Resumo -->
    <div class="row mb-4 text-center">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h4>Total de Produtos</h4>
                    <h2>@Model.TotalProdutos</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <h4>Faturamento Total</h4>
                    <h2>R$ @Model.FaturamentoTotal.ToString("F2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <h4>Total de Categorias</h4>
                    <h2>@Model.TotalCategorias</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow p-3">
                <h5 class="text-center">Produtos por Categoria</h5>
                <canvas id="graficoProdutos"></canvas>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow p-3">
                <h5 class="text-center">Faturamento por Categoria</h5>
                <canvas id="graficoFaturamento"></canvas>
            </div>
        </div>
        <div class="alert alert-success text-center">
            <h4>💰 Faturamento Total: R$ @ViewBag.TotalFaturamento.ToString("F2")</h4>
        </div>
    </div>
</div>

<script>
    const categorias = @Html.Raw(JsonConvert.SerializeObject(Model.Categorias.Select(c => c.Categoria)));
    const totais = @Html.Raw(JsonConvert.SerializeObject(Model.Categorias.Select(c => c.TotalProdutos)));
    const faturamentos = @Html.Raw(JsonConvert.SerializeObject(Model.Categorias.Select(c => c.Faturamento)));

    // Gráfico 1 - Produtos por Categoria
    new Chart(document.getElementById('graficoProdutos'), {
        type: 'bar',
        data: {
            labels: categorias,
            datasets: [{
                label: 'Quantidade de Produtos',
                data: totais,
                backgroundColor: '#0d6efd'
            }]
        },
        options: {
            scales: { y: { beginAtZero: true } }
        }
    });

    // Gráfico 2 - Faturamento por Categoria
    new Chart(document.getElementById('graficoFaturamento'), {
        type: 'pie',
        data: {
            labels: categorias,
            datasets: [{
                label: 'Faturamento (R$)',
                data: faturamentos,
                backgroundColor: ['#198754', '#ffc107', '#dc3545', '#0d6efd', '#6f42c1', '#20c997']
            }]
        }
    });
</script>