@model Esse_deu_certo_MVC_Exemplo.Models.Produto

<h2>Editar Produto</h2>

<form asp-controller="Admin" asp-action="EditarProduto" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="form-group">
        <label>Preço</label>
        <input asp-for="Preco" class="form-control" />
    </div>

    <div class="form-group">
        <label>Categoria</label>
        <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-control">
            <option value="">Selecione uma categoria</option>
        </select>
    </div>

    <div class="form-group">
        <label>Imagem URL</label>
        <input asp-for="ImagemUrl" class="form-control" />
    </div>

    <div class="form-group">
        <label>Descrição</label>
        <textarea asp-for="Descricao" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Quantidade Vendida</label>
        <input asp-for="QuantidadeVendida" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-success">Salvar</button>
    <a href="/Admin/Dashboard" class="btn btn-secondary">Cancelar</a>
    <a href="/Admin/Produtos" class="btn btn-primary">Voltar</a>
</form>
