@model Esse_deu_certo_MVC_Exemplo.Models.Usuario

<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4">👤 Meu Perfil</h2>

        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>Email:</strong> @Model.Email</p>

        <div class="mt-4">
            <a href="/Carrinho/Index" class="btn btn-primary">🛒 Ver Carrinho</a>
            <a href="/Produto/Index" class="btn btn-success">🛍️ Continuar Comprando</a>
            <a href="/Usuario/Logout" class="btn btn-danger float-end">🚪 Sair</a>
        </div>
    </div>
</div>
